# Copia a ".env" y ajusta si quieres otra contraseña local.
# La URI de Spring DEBE usar el mismo usuario y contraseña que Mongo.
#
# La aplicación carga este archivo al arrancar (si existe); las variables de entorno del SO tienen prioridad.

MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=cambia_esto_en_local
MONGO_DATABASE=franchise_db

MONGODB_URI=mongodb://admin:cambia_esto_en_local@localhost:27017/franchise_db?authSource=admin


